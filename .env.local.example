# ============================================================
# SMTP Configuration for Contact Form
# ============================================================
#
# CÓMO CONFIGURAR:
#
# 1. Entra a https://myaccount.google.com/apppasswords
# 2. Selecciona "Mail" y "Windows Computer" (o tu dispositivo)
# 3. Google genera una contraseña de 16 caracteres
# 4. Copia esa contraseña aquí en SMTP_PASS (sin espacios)
# 5. Guarda este archivo como .env.local (sin .example)
#
# ============================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=charlia.agency@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Las solicitudes del formulario se enviarán a: charlia.agency@gmail.com
# Asegúrate de que ese email pueda recibir mensajes SMTP
